{
  "name": "claudia-sofia-alvarez-portfolio",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "dev": "npm-run-all --parallel start build:css",
    "start": "vite",
    "build": "vite build",
    "build:css": "tailwindcss -i ./src/input.css -o ./src/output.css --watch",
    "preview": "vite preview",
    "prepare": "husky install",
    "format": "prettier --write '**/*.{js,ts,vue,json}'",
    "format-staged": "prettier --write",
    "lint": "eslint . --fix --ignore-pattern dist .gitignore"
  },
  "husky": {
    "hooks": {
      "pre-commit": "echo \"[Husky] pre-commit\""
    }
  },
  "dependencies": {
    "vue": "^3.5.13"
  },
  "devDependencies": {
    "@eslint/js": "^9.16.0",
    "@vitejs/plugin-vue": "^5.1.4",
    "eslint": "^9.16.0",
    "eslint-plugin-vue": "^9.32.0",
    "globals": "^15.13.0",
    "husky": "^8.0.0",
    "lint-staged": "^15.2.10",
    "npm-run-all": "^4.1.5",
    "prettier": "^3.3.3",
    "tailwindcss": "^3.4.14",
    "typescript-eslint": "^8.17.0",
    "vite": "^5.4.10"
  },
  "lint-staged": {
    "src/**/*.{js,ts,vue,html,css}": "prettier --write",
    "src/**/*.{js,ts,vue}": "eslint --fix"
  }
}
