{
  "name": "claudia-sofia-alvarez-portfolio",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "dev": "pnpm run --parallel build:css start",
    "start": "vite",
    "build": "vite build",
    "build:css": "tailwindcss -i ./src/input.css -o ./src/output.css --watch",
    "preview": "vite preview",
    "prepare": "husky install",
    "format": "prettier --write '**/*.{js,ts,vue,json}'",
    "format-staged": "prettier --write",
    "lint": "eslint . --fix --ignore-pattern dist .gitignore",
    "deploy": "gh-pages -d dist"
  },
  "husky": {
    "hooks": {
      "pre-commit": "echo \"[Husky] pre-commit\""
    }
  },
  "dependencies": {
    "@headlessui/vue": "^1.7.23",
    "@heroicons/vue": "^2.2.0",
    "vue": "^3.5.14",
    "vue-router": "^4.6.3"
  },
  "devDependencies": {
    "@eslint/js": "^9.27.0",
    "@vitejs/plugin-vue": "^5.2.4",
    "eslint": "^9.27.0",
    "eslint-plugin-vue": "^9.33.0",
    "gh-pages": "^6.3.0",
    "globals": "^15.15.0",
    "husky": "^8.0.3",
    "lint-staged": "^15.5.2",
    "prettier": "^3.5.3",
    "tailwindcss": "^3.4.17",
    "typescript-eslint": "^8.32.1",
    "vite": "^6.3.5",
    "vite-svg-loader": "^5.1.0"
  },
  "lint-staged": {
    "src/**/*.{js,ts,vue,html,css}": "prettier --write",
    "src/**/*.{js,ts,vue}": "eslint --fix"
  }
}
